APP_NAME=HireFlow

# Database
POSTGRES_PASSWORD=your_db_password
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/hireflow

# Authentication — generate with: openssl rand -hex 32
SECRET_KEY=replace_with_a_real_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API KEY — get yours at console.groq.com
GROQ_API_KEY=your_groq_api_key

# Email / Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_NAME=HireFlow

# Testing — set to 1 to disable rate limiting during bulk tests
DISABLE_RATE_LIMIT=0
